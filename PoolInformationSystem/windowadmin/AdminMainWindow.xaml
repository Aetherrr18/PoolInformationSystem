<Window x:Class="PoolInformation.WindowAdmin.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoolInformation.WindowAdmin"
        mc:Ignorable="d"
            Title="Спортивный комплекс: Плавание - Администратор" 
    Height="900" Width="1200"
    WindowStartupLocation="CenterScreen"
    Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхнее меню с вкладками и информацией о администраторе -->
        <Border Grid.Row="0" 
            Background="White" 
            BorderBrush="#D3D3D3" 
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Горизонтальные вкладки -->
                <TabControl Grid.Column="0" 
                        x:Name="MainTabControl"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="20,0,0,0">

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="25,15">
                                            <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#b4d5e8"/>
                                                <Setter TargetName="Border" Property="CornerRadius" Value="5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="КЛИЕНТЫ" FontSize="16"/>
                    <TabItem Header="АБОНЕМЕНТЫ" FontSize="16"/>
                    <TabItem Header="СПРАВОЧНИКИ" FontSize="16"/>
                    <TabItem Header="ПОЛЬЗОВАТЕЛИ" FontSize="16"/>
                </TabControl>

                <!-- Информация о администраторе и кнопка выхода -->
                <StackPanel Grid.Column="1" 
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0">

                    <TextBlock Text="Иванов А.А." 
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                    <Separator Width="1" 
                           Background="#D3D3D3"
                           Margin="0,5"
                           VerticalAlignment="Stretch"/>

                    <Button Content="ВЫХОД" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0" Click="Button_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Основная область контента -->
        <Border Grid.Row="1" 
            Background="White" 
            Margin="20"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#D3D3D3">

            <TabControl Grid.Row="1" 
                    SelectedIndex="{Binding SelectedIndex, ElementName=MainTabControl}"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="0">

                <!-- Вкладка КЛИЕНТЫ -->
                <TabItem>
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок и поиск -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="СПИСОК КЛИЕНТОВ" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#b4d5e8"
                                       Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Поиск:" 
                                           Foreground="#808080"
                                           VerticalAlignment="Center"
                            Margin="0,0,10,0"/>

                                <Border BorderBrush="#D3D3D3" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Background="White">
                                    <TextBox x:Name="SearchClientsTextBox" 
                             BorderThickness="0" 
                             Padding="10,8"
                             Width="300"
                             FontSize="14"
                             VerticalAlignment="Center"
                             TextChanged="SearchClientsTextBox_TextChanged"/>
                                </Border>

                                <Button Content="УДАЛИТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0"
                        Click="BtnDeleteClient_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Таблица клиентов -->
                        <Border Grid.Row="1" 
                BorderBrush="#D3D3D3" 
                BorderThickness="1" 
                CornerRadius="5">
                            <DataGrid x:Name="DgClients"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Код" Binding="{Binding UserId}" Width="80"/>
                                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                                    <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="150"/>
                                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="120"/>
                                    <DataGridTextColumn Header="Пол" Binding="{Binding Genders.GenderName}" Width="100"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                                    <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Вкладка АБОНЕМЕНТЫ -->
                <TabItem>
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок и кнопки -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="СПИСОК АБОНЕМЕНТОВ" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#b4d5e8"
                       Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="ДОБАВИТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Click="BtnAddSubscription_Click"/>

                                <Button Content="РЕДАКТИРОВАТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0"
                        Click="BtnEditSubscription_Click"/>

                                <Button Content="УДАЛИТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0"
                        Click="BtnDeleteSubscription_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Таблица абонементов -->
                        <Border Grid.Row="1" 
                BorderBrush="#D3D3D3" 
                BorderThickness="1" 
                CornerRadius="5">
                            <DataGrid x:Name="DgSubscriptions"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      CanUserAddRows="False"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Код" Binding="{Binding SubscriptionId}" Width="80"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding NameSubscriptionId}" Width="200"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding SubscriptionTypes.TypeName}" Width="150"/>
                                    <DataGridTextColumn Header="Комментарий к типу" Binding="{Binding Comment}" Width="150"/>
                                    <DataGridTextColumn Header="Кол-во занятий" Binding="{Binding MaxVisits}" Width="150"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="120"/>
                                    <DataGridTextColumn Header="Продолжительность дней" Binding="{Binding DurationDays}" Width="120"/>
                                    <DataGridTextColumn Header="Скидка" Binding="{Binding Discounts.DiscountName}" Width="100"/>
                                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>


                <!-- Вкладка СПРАВОЧНИКИ -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="40">
                        <StackPanel>

                            <TextBlock Text="СПРАВОЧНИКИ" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#b4d5e8"
                       Margin="0,0,0,30"/>

                            <!-- Медицинские группы -->
                            <Border BorderBrush="#D3D3D3" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="25"
                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="МЕДИЦИНСКИЕ ГРУППЫ" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="ДОБАВИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Click="BtnAddMedicalGroup_Click"/>

                                        <Button Content="РЕДАКТИРОВАТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnEditMedicalGroup_Click"/>

                                        <Button Content="УДАЛИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnDeleteMedicalGroup_Click"/>
                                    </StackPanel>

                                    <!-- ЗАМЕНИЛИ ListBox НА DataGrid -->
                                    <DataGrid x:Name="DgMedicalGroups" 
                              Height="150"
                              Margin="0,15,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Код" 
                                                Binding="{Binding MedicalGroupId}" 
                                                Width="80"/>
                                            <DataGridTextColumn Header="Название группы" 
                                                Binding="{Binding GroupName}" 
                                                Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Скидки -->
                            <Border BorderBrush="#D3D3D3" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="25"
                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="СКИДКИ" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="ДОБАВИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Click="BtnAddDiscount_Click"/>

                                        <Button Content="РЕДАКТИРОВАТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnEditDiscount_Click"/>

                                        <Button Content="УДАЛИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnDeleteDiscount_Click"/>
                                    </StackPanel>

                                    <DataGrid x:Name="DgDiscounts" 
                              Height="150"
                              Margin="0,15,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Код" 
                                                Binding="{Binding DiscountId}" 
                                                Width="80"/>
                                            <DataGridTextColumn Header="Название" 
                                                Binding="{Binding DiscountName}" 
                                                Width="150"/>
                                            <DataGridTextColumn Header="Процент %" 
                                                Binding="{Binding DiscountPercent}" 
                                                Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Типы абонементов -->
                            <Border BorderBrush="#D3D3D3" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="25"
                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="ТИПЫ АБОНЕМЕНТОВ" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="ДОБАВИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Click="BtnAddType_Click"/>

                                        <Button Content="РЕДАКТИРОВАТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnEditType_Click"/>

                                        <Button Content="УДАЛИТЬ" 
                                Background="#b4d5e8"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15,8"
                                Margin="10,0,0,0"
                                Click="BtnDeleteType_Click"/>
                                    </StackPanel>

                                    <DataGrid x:Name="DgTypes" 
                              Height="150"
                              Margin="0,15,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Код" 
                                                Binding="{Binding TypeId}" 
                                                Width="80"/>
                                            <DataGridTextColumn Header="Название" 
                                                Binding="{Binding TypeName}" 
                                                Width="150"/>
                                            <DataGridTextColumn Header="Комментарий" 
                                                Binding="{Binding Comment}" 
                                                Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Вкладка ПОЛЬЗОВАТЕЛИ -->
                <TabItem>
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок и кнопки -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#b4d5e8"
                       Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="ДОБАВИТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Click="BtnAddUser_Click"/>

                                <Button Content="РЕДАКТИРОВАТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0"
                        Click="BtnEditUser_Click"/>

                                <Button Content="УДАЛИТЬ" 
                        Background="#b4d5e8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,8"
                        Margin="15,0,0,0"
                        Click="BtnDeleteUser_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Таблица пользователей -->
                        <Border Grid.Row="1" 
                BorderBrush="#D3D3D3" 
                BorderThickness="1" 
                CornerRadius="5">
                            <DataGrid x:Name="DgUsers"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      CanUserAddRows="False"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Код" Binding="{Binding UserId}" Width="80"/>
                                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                                    <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="150"/>
                                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate}" Width="120"/>
                                    <DataGridTextColumn Header="Пол" Binding="{Binding Genders.GenderName}" Width="100"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                                    <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Window>
