<Window x:Class="PoolInformationSystem.WindowClient.GuestMainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Спортивный комплекс: Гостевой доступ"
        Height="850" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ПРОБНЫЕ АБОНЕМЕНТЫ" FontSize="24" FontWeight="Bold" 
                           Foreground="#b4d5e8" VerticalAlignment="Center" Margin="30,0,0,0"/>
                <Button x:Name="BtnLogin" Grid.Column="1" Content="ВОЙТИ В АККАУНТ" Background="#b4d5e8" Foreground="White" 
                        BorderThickness="0" FontSize="14" FontWeight="Bold" Padding="25,12" Margin="0,0,30,0"/>
            </Grid>
        </Border>

        <!-- Список абонементов -->
        <Border Grid.Row="1" Background="White" Margin="30" CornerRadius="10" BorderThickness="1" BorderBrush="#D3D3D3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40">
                    <!-- Карточка 1 -->
                    <Border x:Name="Card1" BorderBrush="#D3D3D3" BorderThickness="1" CornerRadius="8" Padding="25" Margin="0,0,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="TbName1" Text="Загрузка..." FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Тип: " Foreground="#808080" Width="180"/>
                                    <TextBlock x:Name="TbType1" Text="–" Foreground="#333"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Количество занятий: " Foreground="#808080" Width="180"/>
                                    <TextBlock x:Name="TbVisits1" Text="–" Foreground="#333"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Срок действия: " Foreground="#808080" Width="180"/>
                                    <TextBlock x:Name="TbDuration1" Text="–" Foreground="#333"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Скидка: " Foreground="#808080" Width="180"/>
                                    <TextBlock x:Name="TbDiscount1" Text="–" Foreground="#333"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TbPrice1" Text="–" FontSize="24" FontWeight="Bold" Foreground="#b4d5e8" HorizontalAlignment="Right" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnDetails1" Content="ПОДРОБНЕЕ" Background="Transparent" Foreground="#b4d5e8" BorderThickness="1" BorderBrush="#b4d5e8" FontSize="12" FontWeight="Bold" Padding="15,5" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnSubscribe1" Content="ОФОРМИТЬ" Background="#b4d5e8" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Padding="25,10"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>