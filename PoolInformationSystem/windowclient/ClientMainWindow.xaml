<Window x:Class="PoolInformation.WindowClient.ClientMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoolInformation.WindowClient"
        mc:Ignorable="d"
        Title="Спортивный комплекс: Плавание" 
        Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхнее меню с вкладками -->
        <Border Grid.Row="0" 
            Background="White" 
            BorderBrush="#D3D3D3" 
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Горизонтальные вкладки (стилизованный TabControl) -->
                <TabControl Grid.Column="0" 
                        x:Name="MainTabControl"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="20,0,0,0">

                    <!-- Стиль для вкладок -->
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="25,15">
                                            <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#b4d5e8"/>
                                                <Setter TargetName="Border" Property="CornerRadius" Value="5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- Вкладка Абонементы -->
                    <TabItem Header="АБОНЕМЕНТЫ" FontSize="16"/>

                    <!-- Вкладка О нас -->
                    <TabItem Header="О НАС" FontSize="16"/>

                    <!-- Вкладка Правила -->
                    <TabItem Header="ПРАВИЛА" FontSize="16"/>

                    <!-- Вкладка Контакты -->
                    <TabItem Header="КОНТАКТЫ" FontSize="16"/>
                </TabControl>

                <!-- Информация о клиенте + кнопка выхода -->
                <StackPanel Grid.Column="1" 
                Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="0,0,20,0">

                    <!-- Фамилия и инициалы -->
                    <TextBlock x:Name="TbClientName" 
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#333333"
                   VerticalAlignment="Center"
                   Margin="0,0,15,0"/>

                    <Separator Width="1" 
                   Background="#D3D3D3"
                   Margin="0,5"
                   VerticalAlignment="Stretch"/>

                    <!-- Кнопка выхода -->
                    <Button Content="ВЫЙТИ" 
                Background="#b4d5e8"
                Foreground="White"
                BorderThickness="0"
                FontSize="14"
                FontWeight="Bold"
                Padding="30,12"
                Margin="15,0,0,0"
                Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область контента -->
        <Border Grid.Row="1" 
            Background="White" 
            Margin="20"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#D3D3D3">

            <TabControl Grid.Row="1" 
                    SelectedIndex="{Binding SelectedIndex, ElementName=MainTabControl}"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="0">

                <!-- Содержимое вкладки АБОНЕМЕНТЫ -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
