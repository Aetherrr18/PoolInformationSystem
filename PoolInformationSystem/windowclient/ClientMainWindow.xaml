                                    BorderBrush="#28a745" 
                                    BorderThickness="1" 
                                    CornerRadius="5" 
                                    Padding="15,10" 
                                    Margin="0,0,0,10" 
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅ " FontSize="14" Foreground="#28a745" VerticalAlignment="Center"/>
                                    <TextBlock Text="Вы уже оформили этот абонемент!" 
                                               FontSize="13" FontWeight="SemiBold" Foreground="#28a745" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
