                                <TextBlock Text="• Количество дорожек: 6" Foreground="#333333" FontSize="15" Margin="0,5"/>
                                <TextBlock Text="• Детский бассейн: 5×3 метра" Foreground="#333333" FontSize="15" Margin="0,5"/>
                                <TextBlock Text="• Раздевалки и душевые" Foreground="#333333" FontSize="15" Margin="0,5"/>
                                <TextBlock Text="• Зона отдыха для родителей" Foreground="#333333" FontSize="15" Margin="0,5"/>
