                            <!-- Карточка 1: Пробный -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,25"
                                    x:Name="Card1">
