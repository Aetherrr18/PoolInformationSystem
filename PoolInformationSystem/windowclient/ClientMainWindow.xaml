                                            <TextBlock x:Name="TbVisits1" Text="–" Foreground="#333333"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="Срок действия: " Foreground="#808080" Width="180"/>
                                            <TextBlock x:Name="TbDuration1" Text="–" Foreground="#333333"/>
