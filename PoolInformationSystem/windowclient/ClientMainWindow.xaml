                                    <StackPanel Grid.Column="1" 
                                                HorizontalAlignment="Right" 
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="TbPrice1" Text="–" 
                                                   FontSize="24" FontWeight="Bold" Foreground="#b4d5e8"
