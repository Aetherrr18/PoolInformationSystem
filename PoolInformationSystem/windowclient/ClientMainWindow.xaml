                                       FontSize="28" 
                                       FontWeight="Bold" 
                                       Foreground="#b4d5e8"
                                       Margin="0,0,0,30"/>

                            <!-- ✅ БАННЕР ДЛЯ КАРТОЧКИ 1 -->
