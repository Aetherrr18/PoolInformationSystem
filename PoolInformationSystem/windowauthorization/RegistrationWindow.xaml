<Window x:Class="PoolInformation.WindowAuthorization.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoolInformation.WindowAuthorization"
        mc:Ignorable="d"
        Title="Регистрация" Height="900" Width="1200"
        MinHeight="900" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Border Margin="40" 
                Background="White" 
                CornerRadius="50" 
                Padding="50" 
                BorderThickness="1" 
                BorderBrush="#D3D3D3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Заголовок -->
                    <TextBlock Text="РЕГИСТРАЦИЯ НОВОГО КЛИЕНТА" 
                               FontSize="40" 
                               FontWeight="Bold"
                               Foreground="#b4d5e8" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,25"/>

                    <!-- ТЕЛЕФОН = ЛОГИН -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="📱 Номер телефона (будет использоваться как логин)" 
                                   Foreground="#808080" 
                                   Margin="0,0,0,5" 
                                   FontSize="25"/>
                        <TextBox x:Name="PhoneTextBox" 
                                 FontSize="22" 
                                 Padding="10"
                                 PreviewTextInput="PhoneTextBox_PreviewTextInput"
                                 PreviewKeyDown="PhoneTextBox_PreviewKeyDown"/>
                    </StackPanel>

                    <!-- ФИО -->
                    <StackPanel Orientation="Horizontal" 
                                Margin="0,0,0,20" 
                                HorizontalAlignment="Left">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Фамилия" 
                                       Foreground="#808080" 
                                       Margin="0,0,0,5" 
                                       FontSize="22"/>
                            <TextBox x:Name="LastNameTextBox" 
                                     FontSize="20" 
                                     Width="330" 
                                     Padding="8"
                                     MaxLength="50"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Имя" 
                                       Foreground="#808080" 
                                       Margin="0,0,0,5" 
                                       FontSize="22"/>
                            <TextBox x:Name="FirstNameTextBox" 
                                     FontSize="20" 
                                     Width="325" 
                                     Padding="8"
                                     MaxLength="50"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Отчество (необязательно)" 
                                       Foreground="#808080" 
                                       Margin="0,0,0,5" 
                                       FontSize="22"/>
                            <TextBox x:Name="PatronymicTextBox" 
                                     FontSize="20" 
                                     Width="325" 
                                     Padding="8"
                                     MaxLength="50"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Дата рождения -->
                    <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                        <TextBlock Text="📅 Дата рождения" 
                                   Foreground="#808080" 
                                   FontSize="25"
                                   Width="250"
                                   Margin="0,0,100,0"/>
                        <DatePicker x:Name="BirthDatePicker" 
                                    FontSize="20" 
                                    Padding="8" 
                                    Width="300"/>
                    </StackPanel>

                    <!-- Пол -->
                    <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                        <TextBlock Text="👤 Пол" 
                                   Foreground="#808080" 
                                   Width="250"
                                   Margin="0,0,100,0" 
                                   FontSize="25"/>
                        <ComboBox x:Name="GenderComboBox" 
                                  FontSize="20" 
                                  Padding="8" 
                                  Width="300" 
                                  DisplayMemberPath="GenderName" 
                                  SelectedValuePath="GenderId"/>
                    </StackPanel>

                    <!-- Сообщение об ошибке -->
                    <TextBlock x:Name="MessageTextBlock" 
                               Text="" 
                               Foreground="Red" 
                               FontSize="20" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center" 
                               Margin="0,0,0,15" 
                               Visibility="Collapsed"/>

                    <!-- Панель ввода кода (изначально скрыта) -->
                    <StackPanel x:Name="CodePanel" 
                                Visibility="Collapsed" 
                                Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Код подтверждения" 
                                       Foreground="#808080" 
                                       Margin="0,0,0,5" 
                                       FontSize="22"
                                       HorizontalAlignment="Center"/>
                            <TextBox x:Name="CodeInputBox" 
                                     FontSize="22" 
                                     Width="300" 
                                     Padding="10"
                                     MaxLength="6"
                                     HorizontalAlignment="Center"
                                     PreviewTextInput="NumberValidationTextBox"/>

                            <!-- 🔹 Кнопка "Получить код заново" -->
                            <Button x:Name="ResendCodeButton"
                                    Content="🔄 ПОЛУЧИТЬ КОД ЗАНОВО" 
                                    Background="LightGray" 
                                    Foreground="White"
                                    FontSize="18"
                                    Height="40" 
                                    Width="300"
                                    BorderThickness="0" 
                                    Padding="10,5"
                                    Margin="0,10,0,0" 
                                    Click="ResendCodeButton_Click"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ✅ БЛОК СОГЛАСИЯ НА ОБРАБОТКУ ПДн -->
                    <Border Background="#f8fafc" 
                            CornerRadius="12" 
                            Padding="20" 
                            Margin="0,10,0,25"
                            BorderThickness="1"
                            BorderBrush="#e0e7ef">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkConsent" 
                                          VerticalAlignment="Center" 
                                          Margin="0,0,12,0"
                                          Width="22" Height="22"
                                          Checked="ChkConsent_StateChanged" 
                                          Unchecked="ChkConsent_StateChanged"/>
                                <TextBlock Text="Я даю согласие на обработку персональных данных" 
                                           VerticalAlignment="Center" 
                                           Foreground="#333" 
                                           FontSize="16"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock x:Name="TbConsentLink" 
                                       Text="[Ознакомиться с условиями обработки персональных данных]" 
                                       Foreground="#b4d5e8" 
                                       TextDecorations="Underline" 
                                       Cursor="Hand" 
                                       MouseLeftButtonUp="TbConsentLink_MouseLeftButtonUp" 
                                       Margin="34,8,0,0" 
                                       FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Vertical" Margin="0, 20, 0, 0">
                        <Button x:Name="ActionButton" 
                                Content="ПОЛУЧИТЬ КОД" 
                                Background="#b4d5e8" 
                                Foreground="White"
                                FontSize="30" 
                                Height="50" 
                                Margin="2"
                                Click="ActionButton_Click"
                                IsEnabled="False"/>
                        <Button Content="НАЗАД" 
                                Background="LightGray" 
                                Foreground="White"
                                FontSize="30" 
                                Height="50" 
                                Margin="2"
                                Click="BackButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>