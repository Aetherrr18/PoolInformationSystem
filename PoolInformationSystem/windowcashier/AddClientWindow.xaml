<Window x:Class="PoolInformation.WindowCashier.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoolInformation.WindowCashier"
        mc:Ignorable="d"
        Title="Добавление клиента" 
        Height="750" Width="700"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="#f5f9fc">

    <Border Margin="20" 
            Background="White" 
            CornerRadius="10" 
            Padding="25" 
            BorderThickness="1" 
            BorderBrush="#D3D3D3">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="НОВЫЙ КЛИЕНТ" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#b4d5e8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- 🔹 ТЕЛЕФОН = ЛОГИН -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="📱 Номер телефона *" 
                               Foreground="#808080" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="TbPhone" 
                             FontSize="14" 
                             Padding="8" 
                             Width="550"
                             HorizontalAlignment="Left"
                             MaxLength="12"
                             PreviewTextInput="TbPhone_PreviewTextInput"
                             PreviewKeyDown="TbPhone_PreviewKeyDown"/>
                    <TextBlock Text="Формат: +71234567890" 
                               FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- ФИО -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Фамилия *" Foreground="#808080" Margin="0,0,0,5"/>
                        <TextBox x:Name="TbLastName" FontSize="14" Padding="8" Width="180" MaxLength="50"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Имя *" Foreground="#808080" Margin="0,0,0,5"/>
                        <TextBox x:Name="TbFirstName" FontSize="14" Padding="8" Width="180" MaxLength="50"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Отчество" Foreground="#808080" Margin="0,0,0,5"/>
                        <TextBox x:Name="TbPatronymic" FontSize="14" Padding="8" Width="180" MaxLength="50"/>
                    </StackPanel>
                </StackPanel>

                <!-- Дата рождения -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Дата рождения *" Foreground="#808080" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpBirthDate" FontSize="14" Padding="8" Width="250" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Пол -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Пол *" Foreground="#808080" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbGender" 
                              FontSize="14" 
                              Padding="8"
                              Width="250"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="GenderName"
                              SelectedValuePath="GenderId"/>
                </StackPanel>

                <!-- Сообщение -->
                <TextBlock x:Name="TbMessage" 
                           Text="" 
                           Foreground="Red" 
                           FontSize="12" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           Margin="0,0,0,10" 
                           Visibility="Collapsed"/>

                <!-- Панель кода (скрыта по умолчанию) -->
                <Border x:Name="CodePanel" 
                        Background="#f0f7fb" 
                        Padding="15" 
                        CornerRadius="5" 
                        Margin="0,0,0,15"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🔐 Введите код подтверждения" 
                                   FontWeight="Bold" 
                                   Foreground="#333"
                                   Margin="0,0,0,10"/>
                        <TextBox x:Name="TbCode" 
                                 FontSize="18" 
                                 Padding="8" 
                                 Width="150" 
                                 HorizontalAlignment="Center"
                                 MaxLength="6"
                                 PreviewTextInput="NumberValidation"/>
                        <TextBlock x:Name="TbCodeHint" 
                                   Text="" 
                                   Foreground="#666" 
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <!-- 🔹 Кнопка "Получить код заново" -->
                        <Button x:Name="BtnResendCode"
                                Content="🔄 ПОЛУЧИТЬ КОД ЗАНОВО" 
                                Background="LightGray" 
                                Foreground="#333"
                                FontSize="12"
                                FontWeight="Bold"
                                Padding="15,6"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Click="BtnResendCode_Click"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <StackPanel Orientation="Vertical" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,50,0,0">
                    <Button x:Name="BtnAction" 
                            Content="ПОЛУЧИТЬ КОД" 
                            Background="#b4d5e8" 
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="30,10"
                            Click="BtnAction_Click"/>

                    <Button Content="ОТМЕНА" 
                            Background="LightGray" 
                            Foreground="Black"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="30,10"
                            Margin="0,10"
                            Click="BtnCancel_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
