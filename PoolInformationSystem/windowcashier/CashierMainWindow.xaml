<Window x:Class="PoolInformation.WindowCashier.CashierMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoolInformation.WindowCashier"
        mc:Ignorable="d"
        Title="Спортивный комплекс: Плавание - Кассир" 
        Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхнее меню -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#D3D3D3" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" 
                            x:Name="MainTabControl"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="20,0,0,0">

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="25,15">
                                            <ContentPresenter ContentSource="Header"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#b4d5e8"/>
                                                <Setter TargetName="Border" Property="CornerRadius" Value="5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="КЛИЕНТЫ" FontSize="16"/>
                    <TabItem Header="ОФОРМИТЬ АБОНЕМЕНТ" FontSize="16"/>
                </TabControl>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <TextBlock x:Name="TbCashierName" 
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>

                    <Separator Width="1" 
                               Background="#D3D3D3"
                               Margin="0,5"
                               VerticalAlignment="Stretch"/>

                    <Button Content="ВЫХОД" 
                            Background="#b4d5e8"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="20,8"
                            Margin="15,0,0,0" 
                            Click="Button_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область контента -->
        <Border Grid.Row="1" 
                Background="White" 
                Margin="20"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#D3D3D3">

            <TabControl Grid.Row="1" 
                        SelectedIndex="{Binding SelectedIndex, ElementName=MainTabControl}"
                        BorderThickness="0"
                        Background="Transparent"
                        Margin="0">

                <!-- Вкладка КЛИЕНТЫ -->
                <TabItem>
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="СПИСОК КЛИЕНТОВ" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#b4d5e8"
                                       Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Поиск:" 
                                           Foreground="#808080"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <Border BorderBrush="#D3D3D3" 
                                        BorderThickness="1" 
                                        CornerRadius="4"
                                        Background="White">
                                    <TextBox x:Name="SearchClientsTextBox" 
                                             BorderThickness="0" 
                                             Padding="10,8"
                                             Width="300"
                                             FontSize="14"
                                             VerticalAlignment="Center"
                                             TextChanged="SearchClientsTextBox_TextChanged"/>
                                </Border>

                                <Button Content="ДОБАВИТЬ" 
                                        Background="#b4d5e8"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Padding="20,8"
                                        Margin="15,0,0,0"
                                        Click="BtnAddClient_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" 
                                BorderBrush="#D3D3D3" 
                                BorderThickness="1" 
                                CornerRadius="5">
                            <DataGrid x:Name="DgClients"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Extended"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="None"
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Код" Binding="{Binding UserId}" Width="80"/>
                                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                                    <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="150"/>
                                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="120"/>
                                    <DataGridTextColumn Header="Пол" Binding="{Binding Genders.GenderName}" Width="100"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Вкладка ОФОРМИТЬ АБОНЕМЕНТ -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="40">
                        <StackPanel>
                            <TextBlock Text="ОФОРМЛЕНИЕ АБОНЕМЕНТА" 
                                       FontSize="28" 
                                       FontWeight="Bold" 
                                       Foreground="#b4d5e8"
                                       Margin="0,0,0,30"/>

                            <!-- Шаг 1: Выбор клиента -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="1. КЛИЕНТ" 
                                               FontSize="18" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               Margin="0,0,0,15"/>

                                    <TextBlock Text="Поиск по номеру телефона:" 
                                               Foreground="#808080"
                                               FontSize="13"
                                               Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" 
                                                BorderBrush="#D3D3D3" 
                                                BorderThickness="1" 
                                                CornerRadius="4"
                                                Background="White">
                                            <TextBox x:Name="SearchClientForSubTextBox" 
                                                     BorderThickness="0" 
                                                     Padding="10,8"
                                                     FontSize="14"
                                                     MaxLength="12"
                                                     TextChanged="SearchClientForSubTextBox_TextChanged"
                                                     PreviewKeyDown="SearchClientForSubTextBox_PreviewKeyDown"
                                                     PreviewTextInput="SearchClientForSubTextBox_PreviewTextInput"
                                                     DataObject.Pasting="SearchClientForSubTextBox_DataObjectPasting"/>
                                        </Border>

                                        <Button Grid.Column="1" 
                                                Content="📋 КЛИЕНТЫ" 
                                                Background="#b4d5e8"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Padding="20,8"
                                                Margin="10,0,0,0"
                                                Click="BtnGoToClients_Click"
                                                ToolTip="Перейти к управлению клиентами"/>
                                    </Grid>

                                    <!-- Результат поиска -->
                                    <Border x:Name="SelectedClientPanel" 
                                            Background="#f0f7fb" 
                                            CornerRadius="5" 
                                            Padding="15" 
                                            Margin="0,15,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="✅ Выбран клиент:" 
                                                       FontWeight="Bold" 
                                                       Foreground="#333"
                                                       Margin="0,0,0,10"/>
                                            <TextBlock x:Name="SelectedClientInfo" 
                                                       FontSize="14" 
                                                       Foreground="#555"/>

                                            <!-- Блок активных абонементов клиента -->
                                            <Border Background="White" 
                                                    CornerRadius="5" 
                                                    Padding="10" 
                                                    Margin="0,15,0,0"
                                                    BorderBrush="#D3D3D3"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="📋 Активные абонементы клиента:" 
                                                               FontWeight="Bold" 
                                                               Foreground="#333"
                                                               Margin="0,0,0,10"/>

                                                    <ComboBox x:Name="CbClientSubscriptions" 
                                                              Margin="0,0,0,10"
                                                              FontSize="14"
                                                              SelectionChanged="CbClientSubscriptions_SelectionChanged"
                                                              DisplayMemberPath="DisplayText"/>

                                                    <!-- Информация о выбранном абонемементе -->
                                                    <Border x:Name="SubscriptionInfoBorder" 
                                                            Background="#e8f5e9" 
                                                            CornerRadius="5" 
                                                            Padding="10"
                                                            Visibility="Collapsed">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="Осталось посещений:" 
                                                                               FontSize="12" 
                                                                               Foreground="#666"/>
                                                                    <TextBlock x:Name="TbRemainingVisits" 
                                                                               Text="0" 
                                                                               FontSize="20" 
                                                                               FontWeight="Bold" 
                                                                               Foreground="#28a745"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Действителен до:" 
                                                                               FontSize="12" 
                                                                               Foreground="#666"/>
                                                                    <TextBlock x:Name="TbExpiryDate" 
                                                                               Text="–" 
                                                                               FontSize="16" 
                                                                               FontWeight="Bold" 
                                                                               Foreground="#333"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <TextBlock x:Name="TbSubscriptionStatus" 
                                                                       Text="" 
                                                                       FontSize="12" 
                                                                       Foreground="#666" 
                                                                       FontStyle="Italic"/>

                                                            <Button x:Name="BtnDeductVisit" 
                                                                    Content="✅ СПИСАТЬ ПОСЕЩЕНИЕ" 
                                                                    Background="#28a745" 
                                                                    Foreground="White" 
                                                                    BorderThickness="0" 
                                                                    FontSize="14" 
                                                                    FontWeight="Bold" 
                                                                    Padding="20,8" 
                                                                    Margin="0,10,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Click="BtnDeductVisit_Click"
                                                                    IsEnabled="False"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <TextBlock x:Name="TbNoSubscriptions" 
                                                               Text="Активных абонементов не найдено" 
                                                               Foreground="#999" 
                                                               FontSize="12"
                                                               FontStyle="Italic"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                            </Border>

                                            <TextBlock x:Name="ClientNotFoundHint" 
                                                       Text="ℹ️ Клиент не найден? Перейдите на вкладку «КЛИЕНТЫ» для регистрации нового." 
                                                       Foreground="#b4d5e8"
                                                       FontSize="12"
                                                       Margin="0,10,0,0"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock x:Name="SelectedClientMedical" 
                                                       FontSize="13" 
                                                       Foreground="#888"
                                                       Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Шаг 2: Выбор абонемента -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="2. АБОНЕМЕНТ" 
                                               FontSize="18" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               Margin="0,0,0,20"/>

                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Абонемент *" 
                                                   Foreground="#808080"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <Border BorderBrush="#D3D3D3" 
                                                BorderThickness="1" 
                                                CornerRadius="4"
                                                Background="White">
                                            <ComboBox x:Name="CbSubscription" 
                                                      BorderThickness="0" 
                                                      Padding="10,8"
                                                      FontSize="14"
                                                      SelectionChanged="CbSubscription_SelectionChanged"
                                                      DisplayMemberPath="NameSubscriptionId"
                                                      SelectedValuePath="SubscriptionId"/>
                                        </Border>
                                    </StackPanel>

                                    <Border Background="#f0f7fb" 
                                            CornerRadius="5" 
                                            Padding="15"
                                            Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="Информация об абонемементе" 
                                                       FontWeight="Bold" 
                                                       Foreground="#333"
                                                       Margin="0,0,0,15"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="Тип абонемента" 
                                                               Foreground="#808080"
                                                               FontSize="12"
                                                               Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="TbSubscriptionType" 
                                                               Text="-" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               Foreground="#333"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Количество занятий" 
                                                               Foreground="#808080"
                                                               FontSize="12"
                                                               Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="TbMaxVisits" 
                                                               Text="-" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               Foreground="#333"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="Срок действия" 
                                                               Foreground="#808080"
                                                               FontSize="12"
                                                               Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="TbDuration" 
                                                               Text="-" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               Foreground="#333"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Базовая цена" 
                                                               Foreground="#808080"
                                                               FontSize="12"
                                                               Margin="0,0,0,3"/>
                                                    <TextBlock x:Name="TbBasePrice" 
                                                               Text="0 ₽" 
                                                               FontSize="16" 
                                                               FontWeight="Bold"
                                                               Foreground="#b4d5e8"/>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel>
                                                <TextBlock Text="Комментарий" 
                                                           Foreground="#808080"
                                                           FontSize="12"
                                                           Margin="0,0,0,3"/>
                                                <TextBlock x:Name="TbSubscriptionComment" 
                                                           Text="-" 
                                                           FontSize="13" 
                                                           Foreground="#666"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Скидка" 
                                                   Foreground="#808080"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <Border BorderBrush="#D3D3D3" 
                                                BorderThickness="1" 
                                                CornerRadius="4"
                                                Background="White">
                                            <ComboBox x:Name="CbDiscount" 
                                                      BorderThickness="0" 
                                                      Padding="10,8"
                                                      FontSize="14"
                                                      SelectionChanged="CbDiscount_SelectionChanged"
                                                      DisplayMemberPath="DiscountName"
                                                      SelectedValuePath="DiscountId"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Шаг 3: Оплата -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="3. ОПЛАТА" 
                                               FontSize="18" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               Margin="0,0,0,20"/>

                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Способ оплаты *" 
                                                   Foreground="#808080"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <Border BorderBrush="#D3D3D3" 
                                                BorderThickness="1" 
                                                CornerRadius="4"
                                                Background="White">
                                            <ComboBox x:Name="CbPaymentMethod" 
                                                      BorderThickness="0" 
                                                      Padding="10,8"
                                                      FontSize="14"
                                                      DisplayMemberPath="MethodName"
                                                      SelectedValuePath="MethodId"
                                                      SelectionChanged="CbPaymentMethod_SelectionChanged"/>
                                        </Border>
                                    </StackPanel>

                                    <Border Background="#f0f7fb" 
                                            CornerRadius="5" 
                                            Padding="15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="Стоимость без скидки:" 
                                                           FontSize="14" 
                                                           Foreground="#666"/>
                                                <TextBlock x:Name="TbPriceWithoutDiscount" 
                                                           Grid.Column="1" 
                                                           Text="0 ₽" 
                                                           FontSize="16" 
                                                           FontWeight="SemiBold"
                                                           Foreground="#666"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="Скидка:" 
                                                           FontSize="14" 
                                                           Foreground="#666"/>
                                                <TextBlock x:Name="TbDiscountAmount" 
                                                           Grid.Column="1" 
                                                           Text="0 ₽" 
                                                           FontSize="16" 
                                                           FontWeight="SemiBold"
                                                           Foreground="#28a745"/>
                                            </Grid>

                                            <Separator Margin="0,10"/>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="Итого к оплате:" 
                                                           FontSize="16" 
                                                           FontWeight="Bold"
                                                           Foreground="#333"/>
                                                <TextBlock x:Name="TbTotalAmount" 
                                                           Grid.Column="1" 
                                                           Text="0 ₽" 
                                                           FontSize="28" 
                                                           FontWeight="Bold" 
                                                           Foreground="#b4d5e8"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Шаг 4: Медицинская группа -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="4. МЕДИЦИНСКАЯ ИНФОРМАЦИЯ" 
                                               FontSize="18" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               Margin="0,0,0,20"/>

                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Медицинская группа *" 
                                                   Foreground="#808080"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <Border BorderBrush="#D3D3D3" 
                                                BorderThickness="1" 
                                                CornerRadius="4"
                                                Background="White">
                                            <ComboBox x:Name="CbMedicalGroup" 
                                                      BorderThickness="0" 
                                                      Padding="10,8"
                                                      FontSize="14"
                                                      DisplayMemberPath="GroupName"
                                                      SelectedValuePath="MedicalGroupId"
                                                      SelectionChanged="CbMedicalGroup_SelectionChanged"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Дополнительно -->
                            <Border BorderBrush="#D3D3D3" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,0,0,30">
                                <StackPanel>
                                    <TextBlock Text="5. ДОПОЛНИТЕЛЬНО" 
                                               FontSize="18" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               Margin="0,0,0,15"/>

                                    <CheckBox x:Name="ChkPrintReceipt" 
                                              Content="🖨️ Распечатать чек об оплате" 
                                              Foreground="#333333"
                                              FontSize="14"
                                              Margin="0,0,0,10"/>
                                </StackPanel>
                            </Border>

                            <!-- Кнопка оформить -->
                            <Button x:Name="BtnPurchaseSubscription" 
                                    Content="✅ ОФОРМИТЬ АБОНЕМЕНТ" 
                                    Background="#b4d5e8"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Height="55"
                                    HorizontalAlignment="Center"
                                    Padding="50,0"
                                    Click="BtnPurchaseSubscription_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
